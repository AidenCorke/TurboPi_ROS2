<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="base_link" params="">

    <!-- Base link at wheel axle height -->
    <link name="base_link">
      <visual>
        <origin xyz="0 0 0.0175"/>
        <geometry>
          <box size="0.20 0.095 0.065"/>
        </geometry>
        <material name="gray">
          <color rgba="0.5 0.5 0.5 1"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0.0175"/>
        <geometry>
          <box size="0.20 0.095 0.065"/>
        </geometry>
      </collision>

    </link>

  </xacro:macro>

</robot>
