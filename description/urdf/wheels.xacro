<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="mecanum_wheels" params="">

    <!-- Real geometry -->
    <xacro:property name="wheel_radius" value="0.03"/>
    <xacro:property name="wheel_width" value="0.03"/>
    <xacro:property name="wheelbase" value="0.120"/>
    <xacro:property name="track" value="0.1410"/>

    <!-- Derived offsets -->
    <xacro:property name="offset_x" value="${wheelbase / 2.0}"/>
    <xacro:property name="offset_y" value="${track / 2.0}"/>

    <!-- FRONT RIGHT -->
    <link name="wheel_fr">
      <visual>
        <origin xyz="${offset_x} -${offset_y} 0" rpy="0 1.57 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="${offset_x} -${offset_y} 0" rpy="0 1.57 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="joint_wheel_fr" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_fr"/>
      <origin xyz="${offset_x} -${offset_y} 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- FRONT LEFT -->
    <link name="wheel_fl">
      <visual>
        <origin xyz="${offset_x} ${offset_y} 0" rpy="0 1.57 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="${offset_x} ${offset_y} 0" rpy="0 1.57 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="joint_wheel_fl" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_fl"/>
      <origin xyz="${offset_x} ${offset_y} 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- REAR LEFT -->
    <link name="wheel_rl">
      <visual>
        <origin xyz="-${offset_x} ${offset_y} 0" rpy="0 1.57 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="-${offset_x} ${offset_y} 0" rpy="0 1.57 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="joint_wheel_rl" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_rl"/>
      <origin xyz="-${offset_x} ${offset_y} 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- REAR RIGHT -->
    <link name="wheel_rr">
      <visual>
        <origin xyz="-${offset_x} -${offset_y} 0" rpy="0 1.57 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="-${offset_x} -${offset_y} 0" rpy="0 1.57 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="joint_wheel_rr" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_rr"/>
      <origin xyz="-${offset_x} -${offset_y} 0"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

</robot>
