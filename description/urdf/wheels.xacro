<xacro:macro name="mecanum_wheels" params="">

  <!-- Wheel parameters -->
  <xacro:property name="wheel_radius" value="0.03"/>
  <xacro:property name="wheel_width" value="0.02"/>
  <xacro:property name="wheel_offset_x" value="0.12"/>
  <xacro:property name="wheel_offset_y" value="0.10"/>

  <!-- Front Right -->
  <link name="wheel_fr">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <origin xyz="${wheel_offset_x} -${wheel_offset_y} 0" rpy="0 1.57 0"/>
    </visual>
  </link>
  <joint name="joint_wheel_fr" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fr"/>
    <origin xyz="${wheel_offset_x} -${wheel_offset_y} 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front Left -->
  <link name="wheel_fl">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <origin xyz="${wheel_offset_x} ${wheel_offset_y} 0" rpy="0 1.57 0"/>
    </visual>
  </link>
  <joint name="joint_wheel_fl" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fl"/>
    <origin xyz="${wheel_offset_x} ${wheel_offset_y} 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear Left -->
  <link name="wheel_rl">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <origin xyz="-${wheel_offset_x} ${wheel_offset_y} 0" rpy="0 1.57 0"/>
    </visual>
  </link>
  <joint name="joint_wheel_rl" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rl"/>
    <origin xyz="-${wheel_offset_x} ${wheel_offset_y} 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear Right -->
  <link name="wheel_rr">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <origin xyz="-${wheel_offset_x} -${wheel_offset_y} 0" rpy="0 1.57 0"/>
    </visual>
  </link>
  <joint name="joint_wheel_rr" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rr"/>
    <origin xyz="-${wheel_offset_x} -${wheel_offset_y} 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</xacro:macro>
